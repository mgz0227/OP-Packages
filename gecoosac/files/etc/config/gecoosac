config gecoosac 'config'
	option enabled '0'
	option port '60650'
	option isonlyoneprot '1'
	option m_port '8080'
	option https '0'
	option crt_file '/etc/gecoosac/tls/gecoosac.crt'
	option key_file '/etc/gecoosac/tls/gecoosac.key'
	option upload_dir '/tmp/gecoosac/upload'
	option db_dir '/etc/gecoosac'
	option piddir '/var/run'
	option lang 'zh'
	option debug '0'
	option showtip '0'
	option log '0'
