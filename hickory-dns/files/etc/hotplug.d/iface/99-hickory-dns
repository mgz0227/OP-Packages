#!/bin/sh

. /lib/functions.sh

IF_TO_WATCH="wan_6"
SERVICE="hickory-dns"
DELAY=5
LOCK="/tmp/hickory-hotplug.lock"
TAG="hickory-hotplug"

[ "$INTERFACE" = "$IF_TO_WATCH" ] || exit 0

case "$ACTION" in
    ifup)
        REASON="ifup"
        ;;
    ifupdate)
        [ "$IFUPDATE_ADDRESSES" = "1" ] || \
        [ "$IFUPDATE_ROUTES"    = "1" ] || \
        [ "$IFUPDATE_PREFIXES"  = "1" ] || exit 0

        REASON="ifupdate(addr=${IFUPDATE_ADDRESSES:-0} route=${IFUPDATE_ROUTES:-0} prefix=${IFUPDATE_PREFIXES:-0})"
        ;;
    *)
        exit 0
        ;;
esac

/etc/init.d/${SERVICE} enabled || {
    logger -t "$TAG" "${SERVICE} not enabled, skipping restart"
    exit 0
}

if [ -f "$LOCK" ]; then
    logger -t "$TAG" "Restart already pending, skipping (${REASON})"
    exit 0
fi

logger -t "$TAG" "${IF_TO_WATCH} ${REASON} - ${SERVICE} restart in ${DELAY}s"

(
    touch "$LOCK"
    sleep ${DELAY}

    /etc/init.d/${SERVICE} restart >/dev/null 2>&1
    logger -t "$TAG" "${SERVICE} restarted successfully"

    rm -f "$LOCK"
) &
