#!/bin/sh /etc/rc.common

START=99

CONFIG="luci-app-ipsec-server"
IPSEC_SECRETS_FILE=/etc/ipsec.secrets
IPSEC_CONN_FILE=/etc/ipsec.conf
IPSEC_CERT_DIR=/etc/ipsec.d
IPSEC_CERTS_DIR=${IPSEC_CERT_DIR}/certs
IPSEC_CACERTS_DIR=${IPSEC_CERT_DIR}/cacerts
IPSEC_PRIVATE_DIR=${IPSEC_CERT_DIR}/private
ACME_CERT_DIR=/etc/ssl/acme
IKEV2_EAP_SERVER_CERT=${IPSEC_CERTS_DIR}/ikev2-eap-server-cert.pem
IKEV2_EAP_SERVER_CHAIN=${IPSEC_CACERTS_DIR}/ikev2-eap-chain.pem
IKEV2_EAP_SERVER_KEY=${IPSEC_PRIVATE_DIR}/ikev2-eap-server-key.pem
LEGACY_L2TP_PATH=/var/etc/xl2tpd

vt_clientip=$(uci -q get ${CONFIG}.@service[0].clientip)
vt_ikev2_ipv6_enable=$(uci -q get ${CONFIG}.@service[0].ikev2_ipv6_enable)
vt_ikev2_serverip6=$(uci -q get ${CONFIG}.@service[0].ikev2_serverip6)

ipt_flag="IPSec VPN Server"

log() {
	logger -t "${CONFIG}" "$*"
}

ipsec_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

strip_cidr() {
	printf '%s' "${1%%/*}"
}

prepare_ikev2_eap_acme_certificates() {
	local acme_name="$1"
	local cert_file
	local fullchain_file
	local chain_file
	local key_file

	[ -n "${acme_name}" ] || return 1

	cert_file="${ACME_CERT_DIR}/${acme_name}.crt"
	fullchain_file="${ACME_CERT_DIR}/${acme_name}.fullchain.crt"
	chain_file="${ACME_CERT_DIR}/${acme_name}.chain.crt"
	key_file="${ACME_CERT_DIR}/${acme_name}.key"

	[ -s "${cert_file}" ] || cert_file="${fullchain_file}"

	if [ ! -s "${cert_file}" ] || [ ! -s "${key_file}" ]; then
		log "ACME certificate files for ${acme_name} were not found under ${ACME_CERT_DIR}; configure luci-app-acme and run /etc/init.d/acme renew first"
		return 1
	fi

	mkdir -p ${IPSEC_CERTS_DIR} ${IPSEC_CACERTS_DIR} ${IPSEC_PRIVATE_DIR}
	ln -sfn "${cert_file}" ${IKEV2_EAP_SERVER_CERT} || return 1
	ln -sfn "${key_file}" ${IKEV2_EAP_SERVER_KEY} || return 1

	if [ -s "${chain_file}" ]; then
		ln -sfn "${chain_file}" ${IKEV2_EAP_SERVER_CHAIN} || return 1
	else
		rm -f ${IKEV2_EAP_SERVER_CHAIN}
	fi

	return 0
}

get_enabled_anonymous_secs() {
	uci -q show "${CONFIG}" | grep "${1}\[.*\.enabled='1'" | cut -d '.' -sf2
}

ipt_rule() {
	local ikev2_ipv6_enable=$(uci -q get ${CONFIG}.@service[0].ikev2_ipv6_enable)
	local ikev2_clientip6=$(uci -q get ${CONFIG}.@service[0].ikev2_clientip6)
	local ikev2_ipv6_nat6_enable=$(uci -q get ${CONFIG}.@service[0].ikev2_ipv6_nat6_enable)

	[ -n "${ikev2_ipv6_enable}" ] || ikev2_ipv6_enable=0
	[ -n "${ikev2_ipv6_nat6_enable}" ] || ikev2_ipv6_nat6_enable=1

	if [ "$1" = "add" ]; then
		iptables -t nat -I POSTROUTING -s ${vt_clientip} -m comment --comment "${ipt_flag}" -j MASQUERADE 2>/dev/null
		iptables -I forwarding_rule -s ${vt_clientip} -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
		iptables -I forwarding_rule -m policy --dir in --pol ipsec --proto esp -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
		iptables -I forwarding_rule -m policy --dir out --pol ipsec --proto esp -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
		iptables -I INPUT -p udp -m multiport --dports 500,4500 -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
		iptables -I INPUT -p esp -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
		iptables -t mangle -I OUTPUT -p udp -m multiport --sports 500,4500 -m comment --comment "${ipt_flag}" -j RETURN 2>/dev/null

		if [ "${ikev2_ipv6_enable}" = 1 ] && [ -n "${ikev2_clientip6}" ] && command -v ip6tables >/dev/null 2>&1; then
			[ "${ikev2_ipv6_nat6_enable}" = 1 ] && ip6tables -t nat -I POSTROUTING -s ${ikev2_clientip6} -m comment --comment "${ipt_flag}" -j MASQUERADE 2>/dev/null
			ip6tables -I forwarding_rule -s ${ikev2_clientip6} -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
			ip6tables -I forwarding_rule -m policy --dir in --pol ipsec --proto esp -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
			ip6tables -I forwarding_rule -m policy --dir out --pol ipsec --proto esp -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
			ip6tables -I INPUT -p udp -m multiport --dports 500,4500 -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
			ip6tables -I INPUT -p esp -m comment --comment "${ipt_flag}" -j ACCEPT 2>/dev/null
			ip6tables -t mangle -I OUTPUT -p udp -m multiport --sports 500,4500 -m comment --comment "${ipt_flag}" -j RETURN 2>/dev/null
		fi
	else
		ipt_del() {
			for i in $(seq 1 $($1 -nL $2 2>/dev/null | grep -c "${ipt_flag}")); do
				local index=$($1 --line-number -nL $2 2>/dev/null | grep "${ipt_flag}" | head -1 | awk '{print $1}')
				[ -n "${index}" ] || break
				$1 -w -D $2 $index 2>/dev/null
			done
		}
		ipt_del "iptables" "forwarding_rule"
		ipt_del "iptables" "INPUT"
		ipt_del "iptables -t nat" "POSTROUTING"
		ipt_del "iptables -t mangle" "OUTPUT"
		if command -v ip6tables >/dev/null 2>&1; then
			ipt_del "ip6tables" "forwarding_rule"
			ipt_del "ip6tables" "INPUT"
			ipt_del "ip6tables -t nat" "POSTROUTING"
			ipt_del "ip6tables -t mangle" "OUTPUT"
		fi
	fi
}

gen_include() {
	echo '#!/bin/sh' > /var/etc/ipsecvpn.include
	extract_rules() {
		local save_cmd="$1"
		local table="$2"
		local rules
		rules=$($save_cmd -t "$table" 2>/dev/null | grep "${ipt_flag}" | \
			sed -e 's/^-A \(INPUT\)/-I \1 1/' \
			    -e 's/^-A \(forwarding_rule\)/-I \1 1/' \
			    -e 's/^-A \(POSTROUTING\)/-I \1 1/' \
			    -e 's/^-A \(OUTPUT\)/-I \1 1/')
		[ -n "${rules}" ] || return 0
		echo "*${table}"
		echo "${rules}"
		echo 'COMMIT'
	}
	cat <<-EOF2 >> /var/etc/ipsecvpn.include
		if command -v iptables-save >/dev/null 2>&1 && command -v iptables-restore >/dev/null 2>&1; then
			iptables-save -c 2>/dev/null | grep -v "${ipt_flag}" | iptables-restore -c 2>/dev/null
			iptables-restore -n <<-EOT
			$(extract_rules iptables-save filter)
			$(extract_rules iptables-save nat)
			$(extract_rules iptables-save mangle)
			EOT
		fi
		if command -v ip6tables-save >/dev/null 2>&1 && command -v ip6tables-restore >/dev/null 2>&1; then
			ip6tables-save -c 2>/dev/null | grep -v "${ipt_flag}" | ip6tables-restore -c 2>/dev/null
			ip6tables-restore -n <<-EOT
			$(extract_rules ip6tables-save filter)
			$(extract_rules ip6tables-save nat)
			$(extract_rules ip6tables-save mangle)
			EOT
		fi
	EOF2
	chmod 0755 /var/etc/ipsecvpn.include
	return 0
}

start() {
	local vt_enabled=$(uci -q get ${CONFIG}.@service[0].enabled)
	[ "$vt_enabled" = 0 ] && return 1

	local vt_gateway="${vt_clientip%.*}.1"
	local vt_secret=$(uci -q get ${CONFIG}.@service[0].secret)
	local vt_secret_escaped=$(ipsec_escape "${vt_secret}")
	local ikev2_psk_enable=$(uci -q get ${CONFIG}.@service[0].ikev2_psk_enable)
	local ikev2_eap_enable=$(uci -q get ${CONFIG}.@service[0].ikev2_eap_enable)
	local ikev2_eap_id=$(uci -q get ${CONFIG}.@service[0].ikev2_eap_id)
	local ikev2_eap_acme_name=$(uci -q get ${CONFIG}.@service[0].ikev2_eap_acme_name)
	local ikev2_ipv6_enable=$(uci -q get ${CONFIG}.@service[0].ikev2_ipv6_enable)
	local ikev2_clientip6=$(uci -q get ${CONFIG}.@service[0].ikev2_clientip6)
	local ikev2_serverip6=$(uci -q get ${CONFIG}.@service[0].ikev2_serverip6)
	local ikev2_ipv6_nat6_enable=$(uci -q get ${CONFIG}.@service[0].ikev2_ipv6_nat6_enable)
	local ikev2_any_enable=0
	local ikev2_eap_ready=0
	local ikev2_gateway6=""
	local ipsec_rightdns="${vt_gateway}"
	local ipsec_remoteaccess_ikev2_leftsubnet="0.0.0.0/0"
	local ipsec_remoteaccess_ikev2_rightsourceip="${vt_clientip}"
	local ipsec_ikev2_psk_config=""
	local ipsec_ikev2_eap_config=""
	local ipsec_extra_secrets=""

	[ -n "${ikev2_psk_enable}" ] || ikev2_psk_enable=0
	[ -n "${ikev2_eap_enable}" ] || ikev2_eap_enable=0
	[ -n "${ikev2_ipv6_enable}" ] || ikev2_ipv6_enable=0
	[ -n "${ikev2_ipv6_nat6_enable}" ] || ikev2_ipv6_nat6_enable=1
	[ -n "${ikev2_eap_acme_name}" ] || ikev2_eap_acme_name="${ikev2_eap_id}"

	[ "${ikev2_psk_enable}" = 1 ] && ikev2_any_enable=1
	[ "${ikev2_eap_enable}" = 1 ] && ikev2_any_enable=1

	if [ "${ikev2_ipv6_enable}" = 1 ]; then
		if [ "${ikev2_any_enable}" != 1 ]; then
			log "IKEv2 IPv6 is enabled but all IKEv2 connection types are disabled, skipping IKEv2 IPv6"
			ikev2_ipv6_enable=0
		elif [ -z "${ikev2_clientip6}" ] || [ -z "${ikev2_serverip6}" ]; then
			log "IKEv2 IPv6 is enabled but the IPv6 client/server addresses are incomplete, skipping IKEv2 IPv6"
			ikev2_ipv6_enable=0
		else
			ikev2_gateway6=$(strip_cidr "${ikev2_serverip6}")
			ipsec_rightdns="${vt_gateway},${ikev2_gateway6}"
			ipsec_remoteaccess_ikev2_leftsubnet="0.0.0.0/0,::/0"
			ipsec_remoteaccess_ikev2_rightsourceip="${vt_clientip},${ikev2_clientip6}"
		fi
	fi

	if [ "${ikev2_psk_enable}" = 1 ]; then
		ipsec_ikev2_psk_config=$(cat <<-EOF2
		conn IKEv2-PSK
		  also=RemoteAccess-IKEv2
		  leftauth=psk
		  rightauth=psk
		EOF2
		)
	fi

	if [ "${ikev2_eap_enable}" = 1 ]; then
		if [ -z "${ikev2_eap_id}" ]; then
			log "IKEv2 EAP is enabled but the server ID is empty, skipping IKEv2 EAP"
		elif prepare_ikev2_eap_acme_certificates "${ikev2_eap_acme_name}"; then
			ikev2_eap_ready=1
			ipsec_extra_secrets=$(cat <<-EOF2
		: RSA ikev2-eap-server-key.pem
		EOF2
			)
			ipsec_ikev2_eap_config=$(cat <<-EOF2

		conn IKEv2-EAP
		  also=RemoteAccess-IKEv2
		  leftauth=pubkey
		  leftid=${ikev2_eap_id}
		  leftcert=ikev2-eap-server-cert.pem
		  leftsendcert=always
		  rightauth=eap-mschapv2
		  eap_identity=%identity
		EOF2
			)
		else
			log "Failed to prepare IKEv2 EAP ACME certificate links, skipping IKEv2 EAP"
		fi
	fi

	cat > ${IPSEC_CONN_FILE} <<-EOF2
		# ipsec.conf - strongSwan IPsec configuration file

		config setup
		  uniqueids=no
		  charondebug="cfg 2, dmn 2, ike 2, net 0"

		conn %default
		  dpdaction=clear
		  dpddelay=300s
		  rekey=no
		  left=%defaultroute
		  leftfirewall=yes
		  right=%any
		  ikelifetime=60m
		  keylife=20m
		  rekeymargin=3m
		  keyingtries=1
		  auto=add

		#######################################
		# Remote Access Connections
		#######################################

		conn RemoteAccess
		  ike=aes256-sha256-modp2048,aes128-sha256-modp2048,aes128-sha1-modp2048,aes128-sha1-modp1024,3des-sha1-modp1024,3des-sha1-modp1536
		  esp=aes256-sha256,aes128-sha256,aes128-sha1,3des-sha1

		conn RemoteAccess-IKEv1
		  also=RemoteAccess
		  keyexchange=ikev1
		  leftsubnet=0.0.0.0/0
		  rightsourceip=${vt_clientip}
		  rightdns=${vt_gateway}

		conn RemoteAccess-IKEv2
		  also=RemoteAccess
		  keyexchange=ikev2
		  fragmentation=yes
		  forceencaps=yes
		  leftsubnet=${ipsec_remoteaccess_ikev2_leftsubnet}
		  rightsourceip=${ipsec_remoteaccess_ikev2_rightsourceip}
		  rightdns=${ipsec_rightdns}

		# Cisco IPSec
		conn IKEv1-PSK-XAuth
		  also=RemoteAccess-IKEv1
		  leftauth=psk
		  rightauth=psk
		  rightauth2=xauth

		${ipsec_ikev2_psk_config}${ipsec_ikev2_eap_config}
	EOF2

	cat > ${IPSEC_SECRETS_FILE} <<-EOF2
	# /etc/ipsec.secrets - strongSwan IPsec secrets file
	: PSK "${vt_secret_escaped}"
	${ipsec_extra_secrets}
	EOF2

	local ipsec_users=$(get_enabled_anonymous_secs "@ipsec_users")
	[ -n "${ipsec_users}" ] && {
		for _user in ${ipsec_users}; do
			local u_enabled=$(uci -q get ${CONFIG}.${_user}.enabled)
			[ "${u_enabled}" -eq 1 ] || continue

			local u_username=$(uci -q get ${CONFIG}.${_user}.username)
			[ -n "${u_username}" ] || continue

			local u_password=$(uci -q get ${CONFIG}.${_user}.password)
			[ -n "${u_password}" ] || continue

			local u_password_escaped=$(ipsec_escape "${u_password}")
			printf '%s : XAUTH "%s"\n' "${u_username}" "${u_password_escaped}" >> ${IPSEC_SECRETS_FILE}
			[ "${ikev2_eap_ready}" = 1 ] && printf '%s : EAP "%s"\n' "${u_username}" "${u_password_escaped}" >> ${IPSEC_SECRETS_FILE}
		done
	}
	unset user

	sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1
	if [ "${ikev2_ipv6_enable}" = 1 ]; then
		sysctl -w net.ipv6.conf.all.forwarding=1 >/dev/null 2>&1
		[ -n "${ikev2_ipv6_nat6_enable}" ] || ikev2_ipv6_nat6_enable=1
	fi

	ipt_rule add

	/usr/lib/ipsec/starter --daemon charon --nofork > /dev/null 2>&1 &
	gen_include

	uci -q set network.ipsec_server.ipaddr="${vt_clientip%.*}.1"
	uci -q set network.ipsec_server.netmask="255.255.255.0"
	if [ "${ikev2_ipv6_enable}" = 1 ] && [ -n "${ikev2_serverip6}" ]; then
		uci -q set network.ipsec_server.ip6addr="${ikev2_serverip6}"
	else
		uci -q delete network.ipsec_server.ip6addr >/dev/null 2>&1
	fi
	uci -q commit network >/dev/null
	ifup ipsec_server > /dev/null 2>&1
}

stop() {
	ifdown ipsec_server > /dev/null 2>&1
	top -bn1 | grep "${LEGACY_L2TP_PATH}" | grep -v "grep" | awk '{print $1}' | xargs kill -9 >/dev/null 2>&1
	rm -rf ${LEGACY_L2TP_PATH}
	ps -w | grep "/usr/lib/ipsec" | grep -v "grep" | awk '{print $1}' | xargs kill -9 >/dev/null 2>&1
	ipt_rule del
	rm -rf /var/etc/ipsecvpn.include
}

gen_iface_and_firewall() {
	local vt_gateway4="${vt_clientip%.*}.1"

	uci -q delete network.ipsec_server
	uci -q set network.ipsec_server=interface
	uci -q set network.ipsec_server.device="ipsec0"
	uci -q set network.ipsec_server.proto="static"
	uci -q set network.ipsec_server.ipaddr="${vt_gateway4}"
	uci -q set network.ipsec_server.netmask="255.255.255.0"
	if [ "${vt_ikev2_ipv6_enable}" = 1 ] && [ -n "${vt_ikev2_serverip6}" ]; then
		uci -q set network.ipsec_server.ip6addr="${vt_ikev2_serverip6}"
	else
		uci -q delete network.ipsec_server.ip6addr >/dev/null 2>&1
	fi
	uci -q commit network >/dev/null

	uci -q delete firewall.ipsecserver
	uci -q set firewall.ipsecserver=zone
	uci -q set firewall.ipsecserver.name="ipsecserver"
	uci -q set firewall.ipsecserver.input="ACCEPT"
	uci -q set firewall.ipsecserver.forward="ACCEPT"
	uci -q set firewall.ipsecserver.output="ACCEPT"
	uci -q set firewall.ipsecserver.network="ipsec_server"
	uci -q commit firewall >/dev/null
}

if [ -z "$(uci -q get network.ipsec_server)" ] || [ -z "$(uci -q get firewall.ipsecserver)" ]; then
	gen_iface_and_firewall
fi
