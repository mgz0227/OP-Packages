#!/bin/sh
[ ! -f "/usr/share/ucitrack/luci-app-virtualdog.json" ] && {
    cat > /usr/share/ucitrack/luci-app-virtualdog.json << EEOF
{
    "config": "virtualdog",
    "init": "virtualdog"
}
EEOF
}

uci -q batch <<-EOF >/dev/null
	delete ucitrack.@virtualdog[-1]
	add ucitrack virtualdog
	set ucitrack.@virtualdog[-1].init=virtualdog
	commit ucitrack
EOF

/etc/init.d/virtualdog enable
/etc/init.d/virtualdog start

exit 0
